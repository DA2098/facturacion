# ═══════════════════════════════════════════════════════════════
# .env — Variables de entorno del backend FacturaYa
# ═══════════════════════════════════════════════════════════════
# Copiar como .env y ajustar los valores:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=facturaya
DB_USER=postgres
DB_PASSWORD=password

# JWT Secret
JWT_SECRET=facturaya_secret_key_2025
JWT_EXPIRES=24h
